# Data root config (per-environment, not tracked)
data_paths.json

# Track only biomodel config folders (fly, drosophila_cx, larva, zebrafish_oculomotor, cortex)
config/*
!config/fly/
config/fly/*.yaml
config/fly/archive/*
config/fly/archive_2/*
# cortex/ and drosophila_cx/ task fixtures ARE tracked (user request 2026-05-15).
!config/cortex/
!config/cortex/*.yaml
!config/drosophila_cx/
!config/drosophila_cx/*.yaml
!config/zebrafish/
!config/zebrafish/*.yaml

# Ignore LLM-generated config files (environment-specific, stored in GraphData)
config/**/*_Claude_*.yaml
config/**/*_winner.yaml
# … except in cortex/ and drosophila_cx/, where Claude / winner yamls are tracked.
!config/cortex/*_Claude_*.yaml
!config/cortex/*_winner.yaml
!config/drosophila_cx/*_Claude_*.yaml
!config/drosophila_cx/*_winner.yaml
!config/zebrafish/*_Claude_*.yaml
!config/zebrafish/*_winner.yaml

# Always track flyvis_hybrid_flywireRF configs, even in archive folders
!config/fly/flyvis_hybrid_flywireRF_*.yaml
!config/fly/archive/flyvis_hybrid_flywireRF_*.yaml
!config/fly/archive_2/flyvis_hybrid_flywireRF_*.yaml

# Data files (large simulation data)
*.npy
*.npz
*.pth
*.backup
paper/
# Ignore papers/ except Code_NN (biomodel data generation scripts)
papers/*
!papers/Code_NN/
!papers/*.md
papers/Code_NN/Code_NN/Data/Figure[1-4]/
papers/Code_NN/Code_NN/Data/Figure5/*.npz
papers/Code_NN/Code_NN/Data/Figure5/*.pt
papers/Code_NN/Code_NN/.png
papers/Code_NN/Code_NN/**/.DS_Store
papers/Code_NN/__MACOSX/

# Log folder — nothing tracked
log/

# Ignore edge_index.pt and mask.pt everywhere (recreated from connectivity)
**/edge_index.pt
**/mask.pt

# Hybrid connectome tables
data/hybrid_connectomes/
data/archive

# graphs_data: large generated data, not tracked
graphs_data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# IDE
.devcontainer/
.idea/
.vscode/
*.swp
*.swo
.env
.prettierrc.json

# Benchmark / one-off run scripts (root level only)
run_*.py
test_edge_removal.py
test_null_edges.py
plot_benchmark*.py
plot_edge_removal.py
plot_null_edges_all_metrics.py
plot_two_panel.py
refactor.md

# Local-only scripts + figure outputs
scripts/
# Track only source code in figures/ (.py / .md / .tex); ignore rendered outputs (PDF/PNG/JPG)
figures/*
!figures/*.py
!figures/*.md
!figures/*.tex
# Source code under the per-biomodel subfolders is also tracked.
!figures/drosophila_cx/
figures/drosophila_cx/*
!figures/drosophila_cx/*.py
!figures/drosophila_cx/*.md
!figures/drosophila_cx/*.tex
!figures/cortex/
figures/cortex/*
!figures/cortex/*.py
!figures/cortex/*.md
!figures/cortex/*.tex
!figures/cortex/.gitkeep
!figures/flyvis/
figures/flyvis/*
!figures/flyvis/*.py
!figures/flyvis/*.md
!figures/flyvis/*.tex
!figures/zebrafish/
figures/zebrafish/*
!figures/zebrafish/*.py
!figures/zebrafish/*.md
!figures/zebrafish/*.tex
*.png
*.pdf
*.jpg
*.jpeg

# Code review
flyvis_gnn_code_review*.pdf
code_review_deepmind_v*.py

# LLM exploration (cluster-specific scripts, not tracked)
INR_LLM.py
src/flyvis_gnn/LLM/cluster.py

# LLM instruction directory — track all instruction files
LLM/*
!LLM/instruction_*.md

# OS
.DS_Store
Thumbs.db

# Quarto
/.quarto/
_site/
*.quarto_ipynb
*_files/
*.ipynb

**/*.quarto_ipynb

# Assets (LFS-tracked PNGs/HTMLs)
assets/*.png
assets/*.html

# Docs (latex, pdf, md)

/docs/*.aux
/docs/*.fdb_latexmk
/docs/*.fls
/docs/*.log
/docs/*.out
/docs/*.gz
docs/*.tex
docs/*.pdf
# but track the main companion documents (sources + rendered PDFs)
!docs/drosophila.tex
!docs/zebrafish.tex
!docs/drosophila.pdf
!docs/zebrafish.pdf

# Local-only data dirs (per-branch dev artefacts)
gcamp/

.github/skills/
docs/repo_overview.md
hpc-config.json*

# Claude code settings
# ignore local settings json that each user can set independently
.claude/settings.local.json